{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Container",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/EduTrail.Backend/EduTrail.API/bin/Debug/net10.0/EduTrail.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/EduTrail.Backend/EduTrail.API",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "DB_HOST": "edu-trail-postgres",
        "DB_PORT": "5432",
        "DB_NAME": "EduTrailDb",
        "DB_USER": "postgres",
        "DB_PASS": "EduTrail123!",
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      }
    },
    {
      "name": "Local",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/EduTrail.Backend/EduTrail.API/bin/Debug/net10.0/EduTrail.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/EduTrail.Backend/EduTrail.API",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "DB_HOST": "localhost",
        "DB_PORT": "5432",
        "DB_NAME": "EduTrailDb",
        "DB_USER": "postgres",
        "DB_PASS": "EduTrail123!",
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      }
    }
  ]
}