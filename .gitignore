# ============================================================
# EduTrail .gitignore
# .NET Core + Angular + Docker + SQL Server
# ============================================================

# -----------------------------------------------
# .NET / ASP.NET Core
# -----------------------------------------------
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
.vs/
*.ncrunch*
_NCrunch_*
nCrunchTemp_*
*.DotSettings.user

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/build/
nuget.exe
project.lock.json
project.fragment.lock.json
artifacts/

# Entity Framework Migrations (keep source, ignore compiled output)
# Uncomment below if you want to ignore migrations entirely:
# **/Migrations/

# Publish output
publish/
**/publish/

# -----------------------------------------------
# Secrets & Configuration
# -----------------------------------------------
appsettings.Development.json
appsettings.Local.json
appsettings.Production.json
secrets.json
*.pfx
*.key
*.pem
*.cer
*.crt
.env
.env.*
!.env.example

# -----------------------------------------------
# Angular / Node.js
# -----------------------------------------------
node_modules/
dist/
tmp/
out-tsc/
.angular/

# Angular cache
.angular/cache/

# NPM / Yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# -----------------------------------------------
# Docker
# -----------------------------------------------
.dockerignore

# -----------------------------------------------
# Visual Studio / VS Code
# -----------------------------------------------
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
!.vscode/settings.json

.vs/
*.VC.db
*.VC.VC.opendb

# -----------------------------------------------
# Rider / JetBrains
# -----------------------------------------------
.idea/
*.sln.iml

# -----------------------------------------------
# OS files
# -----------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# -----------------------------------------------
# Test results & coverage
# -----------------------------------------------
TestResults/
coverage/
*.trx
*.coverage
*.coveragexml
lcov.info

# -----------------------------------------------
# Logs
# -----------------------------------------------
*.log
logs/

# -----------------------------------------------
# Dev Certificates (local only)
# -----------------------------------------------
.devcontainer/local_cert.pfx
.devcontainer/local_cert.key
.devcontainer/*.pfx
.devcontainer/*.key
.devcontainer/*.crt
